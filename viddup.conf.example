# This is TOML syntax despite the traditional .conf filename.

[common]
db = "videos.db"
nice = 10

[import]
numjobs = 4
# Used only when creating a new database. Existing databases keep their
# recorded method. Default: "legacy-center". Alternative: "full-frame".
hash_method = "legacy-center"
exclude_dirs = [
  "/PATH/video/Games",
  "/PATH/video/Photos",
]

[search]
profile = "balanced"
exclude_dirs = [
  "/PATH/video/IgnoreDuringDuplicateSearch",
]

# Built-in profiles can be adjusted, and new profiles can be added.
[profiles.precise]
indexlength = 12
radius = 3.0
verify_brightness = true
brightness_correlation = 0.70

[profiles.sensitive]
indexlength = 10
radius = 3.0
verify_brightness = false
